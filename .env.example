# Krishi Bitan - Environment Variables
# Copy this file to .env and fill in your values

# Database Connection (PostgreSQL)
# Get your database URL from your PostgreSQL provider (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Session Secret for JWT Authentication (REQUIRED - min 32 characters)
# Generate a secure random string: openssl rand -base64 32
SESSION_SECRET=your-secure-session-secret-min-32-characters-long
